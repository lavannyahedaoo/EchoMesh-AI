# ==============================================================================
# EchoMesh AI Environment Configuration Example
# Duplicate this file to '.env' and fill in actual credentials for local dev.
# ==============================================================================

# General Application Configuration
APP_NAME="EchoMesh AI"
APP_ENV=local  # local, staging, production
DEBUG=true
API_PORT=8000
FRONTEND_PORT=3000

# Authentication & Security
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=change_me_to_a_secure_random_hex_string_32_bytes_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration (CockroachDB)
COCKROACH_HOST=localhost
COCKROACH_PORT=26257
COCKROACH_USER=root
COCKROACH_PASSWORD=
COCKROACH_DB=echomesh_dev
COCKROACH_SECURE_MODE=false # Set to true in production with valid certificates
DATABASE_URL=postgresql://root@localhost:26257/echomesh_dev?sslmode=disable

# AWS Cloud Services Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_S3_BUCKET_NAME=echomesh-memories-dev

# AI Engine / Amazon Bedrock Settings
BEDROCK_REASONING_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Logging & Monitoring
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGS=true
